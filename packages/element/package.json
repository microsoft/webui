{
  "name": "@btjs/element",
  "version": "1.0.10",
  "description": "BTJS Element Library",
  "main": "./dist/index.js",
  "types": "./dist/dts/index.d.ts",
  "type": "module",
  "files": ["dist"],
  "scripts": {
    "clean": "rimraf -rf dist",
    "build": "pnpm run clean && pnpm run typings && pnpm turbo",
    "turbo": "esbuild ./src/index.ts --bundle --minify --outdir=./dist --sourcemap --format=esm --target=esnext",
    "serve": "esbuild --serve index.ts --bundle --servedir=.",
    "build:test": "esbuild ./src/**/*.ts --outdir=./dist --sourcemap --format=esm --target=esnext --platform=node",
    "test": "node --test ./dist/**/*.spec.js",
    "test:debug": "node --inspect-brk --test --test-only dist/**/*.spec.js",
    "typings": "tsc"
  },
  "dependencies": {
    "@btjs/eval-js": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/dts/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
