{
  "name": "@btjs/tools",
  "version": "1.0.10",
  "description": "BTJS Tools",
  "main": "./dist/index.js",
  "types": "./dist/dts/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf -rf dist",
    "build": "pnpm run clean && pnpm typings && pnpm run turbo",
    "turbo": "esbuild ./src/*.ts --outdir=./dist --sourcemap --format=esm --target=esnext --platform=node",
    "start": "node ./dist/index.js",
    "typings": "tsc",
    "test": "node --test ./dist/**/*.spec.js",
    "test:debug": "node --inspect-brk --test --test-only dist/**/*.spec.js"
  },
  "bin": {
    "btr": "./dist/index.js"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.26.3",
    "@btjs/protocol-js": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.12.8",
    "commander": "^12.0.0",
    "express": "^4.19.2",
    "glob": "^10.3.12",
    "playwright": "^1.43.1",
    "playwright-core": "^1.43.1",
    "rimraf": "^5.0.5"
  },
  "peerDependencies": {
    "esbuild": "^0.23.1",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
