{
  "name": "@btjs/eval-js",
  "version": "1.0.10",
  "description": "BTJS Safge Expression Evaluation",
  "main": "./dist/index.js",
  "types": "./dist/dts/index.d.ts",
  "type": "module",
  "files": ["dist"],
  "scripts": {
    "clean": "rimraf -rf dist",
    "build": "pnpm run clean && pnpm run typings && esbuild ./src/index.ts --bundle --outdir=./dist --sourcemap --format=esm --target=esnext",
    "build:test": "esbuild ./src/**/*.ts --outdir=./dist --sourcemap --format=esm --target=esnext --platform=node",
    "test": "node --test ./dist/**/*.spec.js",
    "test:debug": "node --inspect-brk --test --test-only dist/**/*.spec.js",
    "typings": "tsc"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
