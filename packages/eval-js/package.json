{
  "name": "@btjs/eval-js",
  "version": "1.0.10",
  "description": "BTJS Safge Expression Evaluation",
  "main": "./dist/index.js",
  "types": "./dist/dts/index.d.ts",
  "type": "module",
  "files": ["dist"],
  "scripts": {
    "clean": "rimraf -rf dist",
    "build": "pnpm run clean && pnpm run typings && esbuild ./src/index.ts --bundle --outdir=./dist --sourcemap --format=esm --target=esnext",
    "test": "mocha -r esbuild-register '**/*.spec.ts'",
    "typings": "tsc"
  }
}
