{
  "name": "@btjs/server-express",
  "version": "1.0.10",
  "description": "Express server for BTJS",
  "main": "./dist/index.js",
  "types": "./dist/dts/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf -rf dist",
    "build": "pnpm run clean && pnpm run typings && esbuild ./src/*.ts --outdir=./dist --sourcemap --format=esm --target=esnext --platform=node",
    "typings": "tsc"
  },
  "dependencies": {
    "@btjs/parser-js": "workspace:*",
    "@btjs/protocol-js": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.8",
    "express": "^4.19.2"
  }
}
