# Normalize text files to LF in the repository so macOS/Windows edits do not
# create noisy CRLF/LF churn. Override the few Windows-native file types below.
* text=auto eol=lf

# Windows-native script and solution files.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.sln text eol=crlf

# Common binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.bin binary
*.wasm binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.dll binary
*.exe binary
*.so binary
*.dylib binary
