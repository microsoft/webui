    {
      "name": "index.html",
      "active": true,
      "content": "<h1>Hello, {{name}}!</h1>\n<p>Welcome to the WebUI Playground.</p>\n\n<if condition=\"showGreeting\">\n  <p>{{greeting}}</p>\n</if>\n\n<h2>Team</h2>\n<for each=\"person in people\">\n  <person-card>{{person.name}} - {{person.role}}</person-card>\n</for>\n"
    },
