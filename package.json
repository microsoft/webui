{
  "name": "build-time-js",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "clean": "pnpm --stream -r run clean",
    "build": "pnpm --stream -r run build",
    "test": "pnpm --stream -r run test",
    "start": "pnpm --filter @example/counter-app run start:dev",
    "serve": "pnpm --filter @example/counter-app run start:btr",
    "format": "dprint fmt --config dprint.json"
  },
  "devDependencies": {
    "@types/node": "^22.5.1",
    "@types/sinon": "^17.0.3",
    "commander": "^12.1.0",
    "dprint": "^0.47.2",
    "esbuild": "^0.23.1",
    "esbuild-register": "^3.6.0",
    "rimraf": "^6.0.1",
    "sinon": "^18.0.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
