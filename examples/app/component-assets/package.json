{
  "name": "component-assets-example",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm run build:deps && pnpm run build:protocol && pnpm run build:client && pnpm run copy:data",
    "build:deps": "pnpm --filter @microsoft/webui-framework run build",
    "build:protocol": "cargo run -p microsoft-webui-cli -- build ./src --plugin=webui --out ./dist --emit-component-assets lazy-panel --theme=@microsoft/webui-examples-theme ",
    "build:client": "esbuild src/index.ts --bundle --outdir=dist --format=esm --splitting --chunk-names=chunks/[name]-[hash] --minify",
    "copy:data": "node -e \"require('node:fs').copyFileSync('src/lazy-panel-data.json','dist/lazy-panel-data.json')\"",
    "start:client": "esbuild src/index.ts --bundle --outdir=dist --format=esm --splitting --chunk-names=chunks/[name]-[hash] --sourcemap --watch",
    "start:server": "cargo run -p microsoft-webui-cli -- serve ./src --state ./data/state.json --theme=@microsoft/webui-examples-theme --plugin=webui --emit-component-assets lazy-panel --servedir ./dist --port 3010 --watch",
    "start": "cargo xtask dev component-assets",
    "test": "playwright test",
    "test:update-snapshots": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@microsoft/webui-examples-theme": "workspace:*",
    "@microsoft/webui-framework": "workspace:*",
    "@playwright/test": "catalog:",
    "esbuild": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:"
  }
}
