{
  "name": "component-assets-example",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm run build:deps && pnpm run build:client && pnpm run build:protocol && pnpm run copy:data",
    "build:deps": "pnpm --filter @microsoft/webui --filter @microsoft/webui-framework run build",
    "build:protocol": "cargo run -p microsoft-webui-cli -- build ./src --plugin=webui --components ../external-components --projection-manifest ./dist/webui-projection.json --projection-manifest ./dist/external/webui-projection.json --out ./dist --emit-component-assets lazy-panel,external-panel --theme=@microsoft/webui-examples-theme ",
    "build:client": "node build-client.mjs",
    "copy:data": "node -e \"require('node:fs').copyFileSync('src/lazy-panel-data.json','dist/lazy-panel-data.json')\"",
    "start:client": "pnpm run build:deps && node build-client.mjs --watch",
    "start:server": "cargo run -p microsoft-webui-cli -- serve ./src --state ./data/state.json --theme=@microsoft/webui-examples-theme --plugin=webui --components ../external-components --projection-manifest ./dist/webui-projection.json --projection-manifest ./dist/external/webui-projection.json --emit-component-assets lazy-panel,external-panel --servedir ./dist --port 3010 --watch",
    "start": "cargo xtask dev component-assets",
    "test": "playwright test",
    "test:projection-contract": "node verify-missing-projection.mjs",
    "test:update-snapshots": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@microsoft/webui": "workspace:*",
    "@microsoft/webui-examples-theme": "workspace:*",
    "@microsoft/webui-framework": "workspace:*",
    "@playwright/test": "catalog:",
    "esbuild": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:"
  }
}
